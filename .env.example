# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_PARTYKIT_HOST=localhost:1999
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# [Sprint 3] Sentry DSN para monitoreo de errores en el frontend (Browser)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── PartyKit Server Environment Variables ────────────────────────────────────
# Set these in your partykit.json or PartyKit dashboard under "env"

# Supabase credentials for server-side JWT verification
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# [S1-T3] Shared secret between room servers and the lobby server.
# Room servers send this in the X-Room-Secret header when posting heartbeats.
# If set, the lobby will reject heartbeats without a matching secret.
# Generate with: openssl rand -hex 32
LOBBY_SECRET=your-random-secret-here

# [S1-T2] Comma-separated list of allowed WebSocket origins (in addition to tutigame.com defaults).
# Example: https://staging.tutigame.com,https://preview.tutigame.com
ALLOWED_ORIGINS=

# [S1-T5] Frontend URL for CORS headers on the lobby HTTP endpoint.
FRONTEND_URL=https://tutigame.com

# ── Observabilidad (Sprint 3) ────────────────────────────────────────────────
# [S3-T1] Sentry DSN para el backend (Cloudflare Workers via Toucan-JS)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# [S3-T3] Webhook de Discord para enviar alertas de errores críticos
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN